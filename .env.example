OLLAMA_MODEL=Bored/gigachat3-10B-A1.8:latest
OLLAMA_HOST=http://127.0.0.1:11434
TICK_INTERVAL=5000
MAX_IDLE=999999
MISSION=Stay ready and useful while idle. Do not perform speculative exploration of the project or system without a concrete trigger. If there is no clear task, preserve context, watch for new input, and wait.

# Optional: enables web_search tool
SERPER_API_KEY=your_serper_api_key_here

# Optional: enables episodic memory persistence
MONGODB_URI=mongodb://127.0.0.1:27017/aya-agent
